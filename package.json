{
  "name": "FlagsQuiz",
  "version": "1.0.0",
  "description": "Interactive flag guessing game with MVC architecture",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:full": "node scripts/development/dev-tools.js full --quiet",
    "preview": "vite preview",
    "start": "npm run dev",
    "commit": "node scripts/git/smart-commit.js",
    "commit:push": "node scripts/git/smart-commit.js --stage-all --push",
    "gh:status": "node scripts/git/github-actions-status.js status",
    "gh:watch": "node scripts/git/github-actions-status.js watch-all",
    "deploy:status": "node scripts/git/validate-pages-deployment.js"
  },
  "keywords": ["flags", "quiz", "game", "geography"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
